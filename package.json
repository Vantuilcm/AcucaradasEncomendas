{
  "name": "acucaradas-encomendas",
  "version": "1.0.1",
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "prepare:ios": "node ./scripts/prepare-ios-build.js",
    "postinstall": "patch-package",
    "build:ios": "node -e \"require('fs').mkdirSync('build-artifacts',{recursive:true})\" && eas build --platform ios --profile production_local --local --non-interactive --output ./build-artifacts/Acucaradas.ipa",
    "start": "expo start",
    "web": "expo start --web",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "jest",
    "clean": "rm -rf node_modules && pnpm store prune",
    "reinstall": "pnpm run clean && pnpm install",
    "security:audit": "node ./scripts/security-audit.js",
    "security:deps": "node ./scripts/dependency-check.js",
    "security:check": "pnpm run security:audit && pnpm run security:deps",
    "security:server": "node ./scripts/server-security-check.js",
    "security:mobile": "node ./scripts/mobile-security-check.js",
    "security:all": "node ./scripts/run-security-checks.js",
    "security:logging": "node ./scripts/security-logging.js",
    "security:tests": "node ./scripts/security-tests.js",
    "security:scan": "node ./scripts/scheduled-security-scan.js",
    "security:scan:init": "node ./scripts/scheduled-security-scan.js --init",
    "security:scan:daily": "node ./scripts/scheduled-security-scan.js --run daily",
    "security:scan:weekly": "node ./scripts/scheduled-security-scan.js --run weekly",
    "security:scan:monthly": "node ./scripts/scheduled-security-scan.js --run monthly",
    "security:brute-force": "node -e \"require('./src/utils/brute-force-protection.js').initialize()\"",
    "security:monitor": "node ./scripts/security-monitor.js",
    "security:dashboard": "node -e \"require('./src/middleware/security-dashboard.js').initSecurityDashboard(require('express')(), require('http').createServer())\"",
    "security:dashboard:integrate": "node ./scripts/integrate-security-dashboard.js",
    "build:android": "eas build --platform android --profile production --local --non-interactive",
    "precommit": "node ./scripts/pre-commit.js",
    "pre-build-check": "node ./scripts/pre-build-check.js",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "submit:android": "eas submit -p android --profile production --non-interactive",
    "submit:ios": "eas submit -p ios --profile production --non-interactive",
    "validate-security": "pnpm run security:all"
  },
