  const { View, Button } = require('react-native');
  return {
    Calendar: (props) => (
      <View testID="calendar-mock">
        <Button
          testID="select-date-button"
          title="Select Date"
          onPress={() => props.onDayPress({ dateString: '2026-05-15' })}
        />
      </View>
    ),
    LocaleConfig: {
      locales: {
        'pt-br': {},
      },
    },
  };
});

