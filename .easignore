# .easignore - Configuração para o EAS Build
# Baseado no .gitignore, mas permitindo arquivos injetados pelo CI

# Herdando regras do .gitignore
*

# Permitindo arquivos essenciais para o build
!package.json
!package-lock.json
!app.json
!app.config.js
!eas.json
!babel.config.js
!metro.config.js
!index.js
!App.js
!src/**
!assets/**
!plugins/**
!scripts/**
!hooks/**
!constants/**
!components/**
!navigation/**
!screens/**
!utils/**
!services/**
!context/**
!types/**
!store/**

# PERMITIR ARQUIVOS FIREBASE (Injetados pelo RellBuild no CI)
!google-services.json
!GoogleService-Info.plist

# Bloquear node_modules e outros pesados
node_modules/
.expo/
dist/
web-build/
build/
ios/
android/
*.ipa
*.apk
*.aab
