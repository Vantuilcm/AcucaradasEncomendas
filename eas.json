{
  "cli": {
    "version": ">= 5.9.0",
    "requireCommit": false,
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "credentialsSource": "remote",
      "env": {
        "APP_ENV": "development"
      },
      "channel": "development",
      "ios": {
        "resourceClass": "m-medium",
        "image": "macos-sequoia-15.3-xcode-16.2"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "autoIncrement": true,
      "env": {
        "APP_ENV": "preview",
        "EXPO_PUBLIC_APP_ENV": "preview",
        "EXPO_PUBLIC_PROJECT_ID": "6090106b-e327-4744-bce5-9ddb0d037045"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "resourceClass": "m-medium",
        "image": "macos-sequoia-15.3-xcode-16.2"
      }
    },
    "production": {
      "distribution": "store",
      "autoIncrement": true,
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_APP_ENV": "production",
        "EXPO_PUBLIC_APP_NAME": "Açucaradas Encomendas",
        "EXPO_PUBLIC_PROJECT_ID": "6090106b-e327-4744-bce5-9ddb0d037045"
      },
      "channel": "production",
      "ios": {
        "resourceClass": "m-medium",
        "buildConfiguration": "Release",
        "image": "macos-sequoia-15.3-xcode-16.2"
      },
      "android": {
        "buildType": "app-bundle"
      }
    },
    "production_v5": {
      "extends": "production"
    },
    "beta": {
      "extends": "production",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "vantuilcaramez@gmail.com",
        "ascAppId": "6478954215",
        "appleTeamId": "7L9P9U9Z9R"
      }
    },
    "preview": {
      "android": {
        "track": "internal"
      }
    }
  }
}
