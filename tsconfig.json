{
  "extends": "expo/tsconfig.base.json",
  "compilerOptions": {
    "strict": true,

    "moduleResolution": "bundler",

    "types": ["node", "jest"],

    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,

    "noEmit": true,
    "jsx": "react-native",

    "lib": ["dom", "esnext"],
    "target": "esnext",
    "module": "esnext",

    "isolatedModules": true,

    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    "forceConsistentCasingInFileNames": true
  },

  "include": ["**/*.ts", "**/*.tsx"],

  "exclude": [
    "node_modules",
    "node_modules_old",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js",
    "jest.setup.ts",
    "src/__tests__",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}