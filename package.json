    "expo-router": "^2.0.0",
    "expo-secure-store": "12.3.1",
    "expo-sharing": "~11.5.0",
    "expo-splash-screen": "~0.20.5",
    "expo-status-bar": "1.6.0",
    "expo-updates": "~0.18.19",
    "expo-web-browser": "12.3.2",
    "express": "5.2.1",
