{
  "name": "acucaradas-encomendas",
  "version": "1.0.1",
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "prebuild": "node scripts/validate-env.js",
    "prepare:ios": "node ./scripts/prepare-ios-build.js",
    "postinstall": "patch-package",
    "build:ios": "eas build --platform ios --profile production --local --non-interactive",
    "build:android": "eas build --platform android --profile production --local --non-interactive",
    "rellbuild:scan": "bash ./scripts/security-scan.sh",
    "rellbuild:validate": "node ./scripts/validate-env.js",
    "start": "expo start",
    "web": "expo start --web",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "jest",
    "clean": "rm -rf node_modules",
    "reinstall": "npm run clean && npm install",
    "security:audit": "node ./scripts/security-audit.js",
    "security:deps": "node ./scripts/dependency-check.js",
    "security:check": "npm run security:audit && npm run security:deps",
    "security:server": "node ./scripts/server-security-check.js",
    "security:mobile": "node ./scripts/mobile-security-check.js",
    "security:all": "node ./scripts/run-security-checks.js",
    "security:logging": "node ./scripts/security-logging.js",
    "security:tests": "node ./scripts/security-tests.js",
    "security:scan": "node ./scripts/scheduled-security-scan.js",
    "security:scan:init": "node ./scripts/scheduled-security-scan.js --init",
    "security:scan:daily": "node ./scripts/scheduled-security-scan.js --run daily",
    "security:scan:weekly": "node ./scripts/scheduled-security-scan.js --run weekly",
    "security:scan:monthly": "node ./scripts/scheduled-security-scan.js --run monthly",
    "security:brute-force": "node -e \"require('./src/utils/brute-force-protection.js').initialize()\"",
    "security:monitor": "node ./scripts/security-monitor.js",
    "security:dashboard": "node -e \"require('./src/middleware/security-dashboard.js').initSecurityDashboard(require('express')(), require('http').createServer())\"",
    "security:dashboard:integrate": "node ./scripts/integrate-security-dashboard.js",
    "precommit": "node ./scripts/pre-commit.js",
    "pre-build-check": "node ./scripts/pre-build-check.js",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "submit:android": "eas submit -p android --profile production --non-interactive",
    "submit:ios": "eas submit -p ios --profile production --non-interactive",
    "validate-security": "pnpm run security:all"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "~14.0.4",
    "@firebase/analytics": "^0.10.20",
    "@ide/backoff": "^1.0.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/cli": "^11.3.8",
    "@react-native-community/datetimepicker": "8.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-voice/voice": "3.1.5",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/stack": "6.3.20",
    "@sentry/react-native": "~6.10.0",
    "@stripe/stripe-react-native": "0.38.6",
    "@types/react": "~18.3.12",
    "axios": "^0.27.2",
    "bcryptjs": "^2.4.3",
    "cors": "2.8.5",
    "crypto-js": "^4.1.1",
    "dompurify": "^3.0.5",
    "expo": "~52.0.49",
    "expo-apple-authentication": "~7.1.3",
    "expo-application": "~6.0.2",
    "expo-auth-session": "~6.0.3",
    "expo-build-properties": "~0.13.3",
    "expo-constants": "~17.0.8",
    "expo-dev-client": "~5.0.20",
    "expo-haptics": "~14.0.1",
    "expo-image-picker": "~16.0.6",
    "expo-linking": "~7.0.5",
    "expo-notifications": "~0.29.14",
    "expo-router": "~4.0.22",
    "expo-secure-store": "~14.0.1",
    "expo-sharing": "~13.0.1",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.1",
    "expo-updates": "~0.27.5",
    "expo-web-browser": "~14.0.2",
    "express": "5.2.1",
    "firebase": "^10.7.1",
    "firebase-admin": "^13.7.0",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "4.0.0",
    "onesignal-expo-plugin": "^2.4.0",
    "patch-package": "8.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-calendars": "1.1314.0",
    "react-native-chart-kit": "6.12.0",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-onesignal": "5.3.1",
    "react-native-paper": "^5.15.0",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "0.19.13",
    "stripe": "20.4.0",
    "uuid": "^9.0.0",
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@babel/core": "~7.25.2",
    "@babel/plugin-transform-export-namespace-from": "7.27.1",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/bcryptjs": "2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "9.0.10",
    "@types/supertest": "^6.0.2",
    "@types/ws": "8.18.1",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "babel-plugin-transform-rename-import": "^2.3.0",
    "babel-preset-expo": "~12.0.1",
    "metro": "^0.81.0",
    "metro-config": "^0.81.0",
    "metro-resolver": "^0.81.0",
    "dotenv": "^17.3.1",
    "eslint": "9.39.3",
    "eslint-config-expo": "~8.0.1",
    "expo-device": "~7.0.3",
    "expo-screen-capture": "~7.0.1",
    "jest": "^29.2.1",
    "jest-expo": "~52.0.0",
    "react-test-renderer": "^18.2.0",
    "scheduler": "^0.23.0",
    "supertest": "^7.2.2",
    "typescript": "~5.3.3",
    "watchman": "1.0.0"
  },
  "private": true
}
